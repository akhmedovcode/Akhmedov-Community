<!DOCTYPE html>
<html lang="uz">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Bir martalik Messenger</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- PeerJS for WebRTC cross-browser/device communication -->
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <style>
        :root {
            --primary: #10B981;
            /* Emerald Green */
            --primary-dark: #059669;
            --primary-light: #D1FAE5;
            --bg-color: #F3F4F6;
            --white: #FFFFFF;
            --text-dark: #1F2937;
            --text-gray: #6B7280;
            --border: #E5E7EB;
            --danger: #EF4444;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --radius-md: 0.5rem;
            --radius-lg: 1rem;
            --radius-full: 9999px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-dark);
            height: 100vh;
            display: flex;
            justify-content: center;
            overflow: hidden;
        }

        .app-container {
            width: 100%;
            max-width: 480px;
            background-color: var(--white);
            height: 100vh;
            position: relative;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow-2xl);
            overflow: hidden;
        }

        /* Utility */
        .hidden {
            display: none !important;
        }

        .flex {
            display: flex;
        }

        .flex-col {
            flex-direction: column;
        }

        .items-center {
            align-items: center;
        }

        .justify-center {
            justify-content: center;
        }

        .justify-between {
            justify-content: space-between;
        }

        .flex-1 {
            flex: 1;
            overflow-y: auto;
        }

        button {
            cursor: pointer;
            border: none;
            outline: none;
            background: none;
            font-family: inherit;
        }

        /* Headers */
        .header {
            padding: 1rem 1.5rem;
            background-color: var(--white);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 10;
        }

        .header h1 {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--text-dark);
        }

        /* Screens */
        .screen {
            display: none;
            flex-direction: column;
            height: 100%;
            width: 100%;
            position: absolute;
            top: 0;
            left: 0;
            background: var(--white);
        }

        .screen.active {
            display: flex;
        }

        /* Onboarding Screen */
        #onboarding-screen {
            justify-content: center;
            align-items: center;
            padding: 2rem;
            text-align: center;
            background: linear-gradient(135deg, var(--white) 0%, var(--primary-light) 100%);
        }

        .logo-circle {
            width: 80px;
            height: 80px;
            background-color: var(--primary);
            color: var(--white);
            border-radius: var(--radius-full);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin-bottom: 2rem;
            box-shadow: var(--shadow-lg);
        }

        .id-display {
            font-size: 2.5rem;
            font-weight: 700;
            letter-spacing: 2px;
            color: var(--primary-dark);
            margin: 1rem 0;
            padding: 1rem 2rem;
            background: var(--white);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md);
            border: 2px dashed var(--primary);
        }

        .btn-primary {
            background-color: var(--primary);
            color: var(--white);
            padding: 1rem 2rem;
            border-radius: var(--radius-full);
            font-size: 1.125rem;
            font-weight: 600;
            margin-top: 2rem;
            width: 100%;
            transition: all 0.2s;
            box-shadow: var(--shadow-md);
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            transform: translateY(-2px);
        }

        /* Chat List Screen */
        .chat-list {
            list-style: none;
            padding: 0;
            margin: 0;
            overflow-y: auto;
            flex: 1;
            padding-bottom: 80px;
            /* Space for nav */
        }

        .chat-item {
            display: flex;
            align-items: center;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border);
            cursor: pointer;
            transition: background-color 0.2s;
        }

        .chat-item:hover {
            background-color: var(--bg-color);
        }

        .avatar {
            width: 50px;
            height: 50px;
            border-radius: var(--radius-full);
            background-color: var(--primary-light);
            color: var(--primary-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 1.25rem;
            margin-right: 1rem;
        }

        .chat-info {
            flex: 1;
        }

        .chat-name {
            font-weight: 600;
            font-size: 1.125rem;
            margin-bottom: 0.25rem;
        }

        .chat-preview {
            color: var(--text-gray);
            font-size: 0.875rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 200px;
        }

        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            flex: 1;
            color: var(--text-gray);
            text-align: center;
            padding: 2rem;
        }

        .empty-state i {
            font-size: 3rem;
            color: var(--border);
            margin-bottom: 1rem;
        }

        /* Bottom Navigation */
        .bottom-nav {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 70px;
            background-color: var(--white);
            box-shadow: 0 -4px 10px rgba(0, 0, 0, 0.05);
            display: flex;
            justify-content: space-around;
            align-items: center;
            padding: 0 1rem;
            z-index: 20;
            border-top-left-radius: 20px;
            border-top-right-radius: 20px;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: var(--text-gray);
            font-size: 1.5rem;
            transition: color 0.2s;
            position: relative;
            flex: 1;
        }

        .nav-item.active {
            color: var(--primary);
        }

        /* Floating Action Button */
        .fab-wrapper {
            position: relative;
            top: -20px;
            display: flex;
            justify-content: center;
            flex: 1;
        }

        .fab {
            width: 60px;
            height: 60px;
            background-color: var(--primary);
            color: var(--white);
            border-radius: var(--radius-full);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.75rem;
            box-shadow: 0 8px 15px rgba(16, 185, 129, 0.4);
            transition: transform 0.2s;
            border: 4px solid var(--white);
        }

        .fab:hover {
            transform: scale(1.05);
        }

        /* Profile Screen */
        #profile-screen {
            padding-bottom: 80px;
        }

        .profile-header {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 3rem 2rem;
            background: linear-gradient(to bottom, var(--primary-light), var(--white));
        }

        .profile-avatar {
            width: 100px;
            height: 100px;
            border-radius: var(--radius-full);
            background-color: var(--primary);
            color: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            margin-bottom: 1rem;
            box-shadow: var(--shadow-md);
        }

        .profile-id {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-dark);
            letter-spacing: 1px;
        }

        /* Modal */
        .modal-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 50;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }

        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .modal-content {
            background: var(--white);
            width: 90%;
            max-width: 340px;
            border-radius: var(--radius-lg);
            padding: 2rem;
            box-shadow: var(--shadow-2xl);
            transform: translateY(20px);
            transition: transform 0.3s;
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0);
        }

        .input-group {
            margin: 1.5rem 0;
        }

        .id-input {
            width: 100%;
            padding: 1rem;
            font-size: 1.5rem;
            text-align: center;
            letter-spacing: 4px;
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            outline: none;
            transition: border-color 0.2s;
        }

        .id-input:focus {
            border-color: var(--primary);
        }

        .modal-actions {
            display: flex;
            gap: 1rem;
        }

        .btn-cancel {
            flex: 1;
            padding: 0.75rem;
            background: var(--bg-color);
            color: var(--text-dark);
            border-radius: var(--radius-md);
            font-weight: 600;
        }

        .btn-confirm {
            flex: 1;
            padding: 0.75rem;
            background: var(--primary);
            color: var(--white);
            border-radius: var(--radius-md);
            font-weight: 600;
        }

        /* Chat View Screen */
        #chat-view-screen {
            z-index: 30;
        }

        .chat-header {
            display: flex;
            align-items: center;
            padding: 1rem;
            background: var(--white);
            border-bottom: 1px solid var(--border);
        }

        .back-btn {
            font-size: 1.25rem;
            color: var(--text-dark);
            margin-right: 1rem;
            padding: 0.5rem;
        }

        .messages-container {
            flex: 1;
            padding: 1rem;
            background: var(--bg-color);
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .message {
            max-width: 80%;
            padding: 0.75rem 1rem;
            border-radius: 1rem;
            position: relative;
            animation: fadeIn 0.3s ease;
            word-wrap: break-word;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .message.sent {
            align-self: flex-end;
            background-color: var(--primary);
            color: var(--white);
            border-bottom-right-radius: 0.25rem;
        }

        .message.received {
            align-self: flex-start;
            background-color: var(--white);
            color: var(--text-dark);
            border-bottom-left-radius: 0.25rem;
            box-shadow: var(--shadow-sm);
        }

        .msg-actions {
            display: flex;
            gap: 0.5rem;
            margin-top: 0.25rem;
            font-size: 0.75rem;
            justify-content: flex-end;
            opacity: 0.7;
        }

        .msg-actions button {
            color: inherit;
        }

        .msg-actions button:hover {
            opacity: 1;
        }

        .chat-input-area {
            padding: 1rem;
            background: var(--white);
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .action-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            color: var(--text-gray);
            background: transparent;
            transition: all 0.2s;
        }

        .action-btn:hover {
            background: var(--bg-color);
            color: var(--primary);
        }

        .action-btn.recording {
            color: var(--danger);
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.1);
            }

            100% {
                transform: scale(1);
            }
        }

        .chat-input {
            flex: 1;
            padding: 0.75rem 1rem;
            border: 1px solid var(--border);
            border-radius: var(--radius-full);
            outline: none;
            font-size: 1rem;
        }

        .chat-input:focus {
            border-color: var(--primary);
        }

        .chat-input:disabled {
            background: var(--bg-color);
        }

        .send-btn {
            width: 45px;
            height: 45px;
            border-radius: var(--radius-full);
            background: var(--primary);
            color: var(--white);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            transition: background 0.2s;
        }

        .send-btn:hover {
            background: var(--primary-dark);
        }

        .msg-image {
            max-width: 100%;
            border-radius: 0.5rem;
            margin-top: 0.25rem;
        }

        .img-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
            gap: 5px;
            margin-top: 0.25rem;
        }

        .img-grid img {
            width: 100%;
            height: 80px;
            object-fit: cover;
            border-radius: 0.5rem;
        }

        .msg-audio {
            max-width: 220px;
            height: 40px;
            margin-top: 0.25rem;
            outline: none;
        }

        .msg-time {
            font-size: 0.65rem;
            opacity: 0.7;
            text-align: right;
            margin-top: 4px;
        }

        .unread-badge {
            background-color: var(--danger);
            color: var(--white);
            font-size: 0.75rem;
            font-weight: bold;
            border-radius: var(--radius-full);
            min-width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 6px;
            margin-left: auto;
        }

        .image-preview-area {
            padding: 0.5rem 1rem;
            background: var(--bg-color);
            border-top: 1px solid var(--border);
            display: none;
            align-items: center;
            justify-content: flex-start;
            gap: 10px;
            overflow-x: auto;
        }

        .image-preview-area.active {
            display: flex;
        }

        .preview-item {
            position: relative;
            display: inline-block;
        }

        .image-preview-thumb {
            height: 60px;
            min-width: 60px;
            object-fit: cover;
            border-radius: var(--radius-md);
            border: 2px solid var(--primary);
            box-shadow: var(--shadow-sm);
        }

        .remove-media-btn {
            position: absolute;
            top: -5px;
            right: -5px;
            width: 20px;
            height: 20px;
            background: var(--danger);
            color: var(--white);
            border-radius: var(--radius-full);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            cursor: pointer;
        }

        .add-more-img-btn {
            height: 60px;
            width: 60px;
            border-radius: var(--radius-md);
            border: 2px dashed var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-size: 1.5rem;
            cursor: pointer;
        }
        
        .edited-tag {
            font-size: 0.65rem;
            opacity: 0.6;
            font-style: italic;
            margin-right: 5px;
        }
    </style>
</head>

<body>

    <div class="app-container">

        <!-- 1. Onboarding Screen -->
        <div id="onboarding-screen" class="screen active">
            <div class="logo-circle">
                <i class="fa-solid fa-bolt"></i>
            </div>
            <h2>Xush kelibsiz!</h2>
            <p style="color: var(--text-gray); margin-top: 0.5rem;">Sizning maxfiy bir martalik ID raqamingiz:</p>

            <div class="id-display" id="generated-id">
                000-000
            </div>

            <p style="color: var(--text-gray); font-size: 0.875rem; margin-top: 1rem;">
                Ushbu ID orqali boshqalar siz bilan bog'lanishi mumkin.
            </p>

            <button class="btn-primary" onclick="startApp()">ID ni olish va Boshlash</button>
        </div>

        <!-- 2. Chat List Screen -->
        <div id="chat-list-screen" class="screen">
            <div class="header">
                <h1>Xabarlar</h1>
            </div>

            <div id="empty-chat-state" class="empty-state">
                <i class="fa-regular fa-comments"></i>
                <h3>Suhbatlar yo'q</h3>
                <p>Yangi suhbat boshlash uchun + tugmasini bosing</p>
            </div>

            <ul class="chat-list" id="chat-list">
                <!-- Chats will be appended here -->
            </ul>
        </div>

        <!-- 3. Profile Screen -->
        <div id="profile-screen" class="screen">
            <div class="header">
                <h1>Profil</h1>
            </div>
            <div class="profile-header">
                <div class="profile-avatar">
                    <i class="fa-solid fa-user-secret"></i>
                </div>
                <p style="color: var(--text-gray); margin-bottom: 0.5rem;">Sizning ID raqamingiz</p>
                <div class="profile-id" id="profile-id-display">000-000</div>
            </div>
            <div style="padding: 2rem;">
                <button class="btn-primary" style="background-color: var(--danger);" onclick="resetApp()">
                    <i class="fa-solid fa-right-from-bracket" style="margin-right: 0.5rem;"></i> Chiqish va O'chirish
                </button>
            </div>
        </div>

        <!-- 4. Chat View Screen -->
        <div id="chat-view-screen" class="screen">
            <div class="chat-header">
                <button class="back-btn" onclick="closeChat()">
                    <i class="fa-solid fa-arrow-left"></i>
                </button>
                <div class="avatar" style="width: 40px; height: 40px; font-size: 1rem;" id="current-chat-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
                <h2 id="current-chat-name" style="font-size: 1.125rem; font-weight: 600;">000-000</h2>
            </div>

            <div class="messages-container" id="messages-container">
                <!-- Messages -->
            </div>

            <div id="image-preview-area" class="image-preview-area">
                <div id="preview-list" style="display: flex; gap: 10px;"></div>
                <button class="add-more-img-btn hidden" id="add-more-img" onclick="triggerImageUpload()"><i class="fa-solid fa-plus"></i></button>
                <div style="flex: 1;"></div>
                <button class="action-btn" style="color: var(--danger);" onclick="cancelMediaPreview()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="chat-input-area">
                <button class="action-btn" onclick="triggerImageUpload()">
                    <i class="fa-solid fa-image"></i>
                </button>
                <input type="file" id="image-upload" accept="image/*" class="hidden" onchange="sendImage(event)">

                <input type="text" id="message-input" class="chat-input" placeholder="Xabar yozing..."
                    autocomplete="off">
                <button class="action-btn" id="mic-btn" onclick="toggleRecording()">
                    <i class="fa-solid fa-microphone"></i>
                </button>
                <button class="send-btn" onclick="sendMessage()">
                    <i class="fa-solid fa-paper-plane"></i>
                </button>
            </div>
        </div>

        <!-- Bottom Navigation -->
        <div id="bottom-nav" class="bottom-nav hidden">
            <button class="nav-item active" onclick="switchTab('chat-list-screen', this)">
                <i class="fa-solid fa-message"></i>
            </button>

            <div class="fab-wrapper">
                <button class="fab" onclick="openNewChatModal()">
                    <i class="fa-solid fa-plus"></i>
                </button>
            </div>

            <button class="nav-item" onclick="switchTab('profile-screen', this)">
                <i class="fa-solid fa-user"></i>
            </button>
        </div>

        <!-- New Chat Modal -->
        <div id="new-chat-modal" class="modal-overlay">
            <div class="modal-content">
                <h3 style="text-align: center; margin-bottom: 0.5rem;">Yangi Suhbat</h3>
                <p style="text-align: center; color: var(--text-gray); font-size: 0.875rem;">
                    Suhbatdoshning 6 xonali ID raqamini kiriting.
                </p>
                <div class="input-group">
                    <input type="text" id="peer-id-input" class="id-input" placeholder="___-___" maxlength="7"
                        oninput="formatIdInput(this)">
                </div>
                <p id="new-chat-error"
                    style="color: var(--danger); font-size: 0.875rem; text-align: center; display: none; margin-bottom: 1rem;">
                </p>
                <div class="modal-actions">
                    <button class="btn-cancel" onclick="closeNewChatModal()">Bekor qilish</button>
                    <button class="btn-confirm" onclick="startNewChat()">Suhbatlashish</button>
                </div>
            </div>
        </div>

    </div>

    <script>
        // State (Only in memory, completely one-time session)
        let myId = '';
        let chats = {}; // Key: peerId, Value: array of messages
        let currentActiveChatId = null;
        let editingMessageId = null;
        let unreadCounts = {};
        
        // PeerJS variables
        let peer;
        let connections = {}; // Key: peerId, Value: PeerJS Connection object
        let pendingConnectionTimeout = null;

        let pendingMedia = { type: null, images: [], audio: null };

        let mediaRecorder;
        let audioChunks = [];
        let isRecording = false;

        // Data Models
        // message = { id: string, type: 'text'|'image'|'audio', content: string (text, base64 url, objectUrl), sender: 'me' | 'peer', timestamp: number }

        function generateId() {
            const p1 = Math.floor(100 + Math.random() * 900);
            const p2 = Math.floor(100 + Math.random() * 900);
            return `${p1}-${p2}`;
        }

        // Initialization
        window.onload = () => {
            // generate fresh ID every entry
            myId = generateId();
            document.getElementById('generated-id').textContent = myId;
            document.getElementById('profile-id-display').textContent = myId;

            // Qo'shimcha mahalliy himoya (faqat huddi shu brauzerdagilar uchun 100% ishlashi uchun)
            let activeIds = JSON.parse(localStorage.getItem('webmessage_active_ids') || '[]');
            if (!activeIds.includes(myId)) {
                activeIds.push(myId);
                localStorage.setItem('webmessage_active_ids', JSON.stringify(activeIds));
            }

            localStorage.setItem('webmessage_beat_' + myId, Date.now());
            setInterval(() => {
                localStorage.setItem('webmessage_beat_' + myId, Date.now());
            }, 2000);

            // Initialize PeerJS
            peer = new Peer(myId, {
                debug: 2
            });

            peer.on('open', (id) => {
                console.log('PeerJS ulangan ID: ' + id);
            });

            peer.on('disconnected', () => {
                peer.reconnect();
            });

            // Kimdir bizga ulansa (kiruvchi ulanish)
            peer.on('connection', (conn) => {
                setupConnection(conn);
            });

            // Peer ulanishda xato bo'lsa
            peer.on('error', (err) => {
                console.error('PeerJS xato:', err.type, err);
                const btn = document.querySelector('.btn-confirm');
                const errMsg = document.getElementById('new-chat-error');

                const isActivelySearching = btn && btn.disabled;

                if (err.type === 'peer-unavailable') {
                    // Mahalliy pulseni tekshiramiz
                    const searchId = document.getElementById('peer-id-input')?.value;
                    const lastBeat = searchId ? localStorage.getItem('webmessage_beat_' + searchId) : null;
                    
                    if (searchId && lastBeat && (Date.now() - parseInt(lastBeat)) <= 5000) {
                        if (btn) { btn.disabled = false; btn.textContent = 'Suhbatlashish'; }
                        if (!chats[searchId]) chats[searchId] = [];
                        connections[searchId] = { isLocalOnly: true };
                        closeNewChatModal();
                        openChat(searchId);
                        renderChatList();
                        return; 
                    }
                    
                    if (isActivelySearching) {
                        if (errMsg) { errMsg.textContent = "Bunday ID mavjud emas!"; errMsg.style.display = 'block'; }
                        if (btn) { btn.disabled = false; btn.textContent = 'Suhbatlashish'; }
                    }

                } else if (err.type === 'network' || err.type === 'server-error' || err.type === 'browser-incompatible') {
                    if (isActivelySearching) {
                        if (errMsg) { errMsg.textContent = "Internet yoki serverda uzilish bo'ldi. Qayta urinib ko'ring!"; errMsg.style.display = 'block'; }
                        if (btn) { btn.disabled = false; btn.textContent = 'Suhbatlashish'; }
                    }
                    setTimeout(() => { if (peer && peer.disconnected && !peer.destroyed) peer.reconnect(); }, 1500);
                }
            });
        };

        window.addEventListener('storage', (e) => {
            if (e.key === 'webmessage_broadcast' && e.newValue) {
                const data = JSON.parse(e.newValue);
                if (data.recipient === myId) {
                    processIncomingMessage(data);
                }
            }
        });

        function processIncomingMessage(data) {
            const peerId = data.sender;
            if (!chats[peerId]) {
                chats[peerId] = [];
            }

            let updatedExists = false;
            let existingIdx = chats[peerId].findIndex(m => m.id === data.id);
            if (existingIdx !== -1) {
                chats[peerId][existingIdx] = {
                    id: data.id,
                    type: data.type,
                    content: data.content,
                    caption: data.caption,
                    sender: 'peer',
                    timestamp: data.timestamp,
                    isEdited: data.isEdited
                };
                updatedExists = true;
            }

            if (!updatedExists) {
                chats[peerId].push({
                    id: data.id,
                    type: data.type,
                    content: data.content,
                    caption: data.caption,
                    sender: 'peer',
                    timestamp: data.timestamp,
                    isEdited: data.isEdited
                });
            }

            // UI ni yangilaymiz
            if (currentActiveChatId === peerId) {
                renderMessages();
            } else {
                unreadCounts[peerId] = (unreadCounts[peerId] || 0) + 1;
            }
            renderChatList();
        }

        function setupConnection(conn) {
            const peerId = conn.peer;
            // Darhol xotiraga olish (Bazan 'open' event ulanish qabul qilinganda ishlamay qoladi)
            connections[peerId] = conn;
            if (!chats[peerId]) {
                chats[peerId] = [];
            }
            renderChatList();

            conn.on('open', () => {
                connections[peerId] = conn;
                if (!chats[peerId]) {
                    chats[peerId] = [];
                }
                renderChatList();
            });

            conn.on('data', (data) => {
                // Ishonch hosil qilish uchun kelgan data orqali ham yangilab qo'yamiz
                connections[conn.peer] = conn;
                processIncomingMessage(data);
            });

            conn.on('close', () => {
                delete connections[conn.peer];
            });
        }

        window.onbeforeunload = () => {
            let activeIds = JSON.parse(localStorage.getItem('webmessage_active_ids') || '[]');
            activeIds = activeIds.filter(id => id !== myId);
            localStorage.setItem('webmessage_active_ids', JSON.stringify(activeIds));
            localStorage.removeItem('webmessage_beat_' + myId);
            
            if (peer) {
                peer.destroy();
            }
        };

        function startApp() {
            showScreen('chat-list-screen');
            document.getElementById('bottom-nav').classList.remove('hidden');
            renderChatList();
        }

        function resetApp() {
            if (confirm("Chiqsangiz barcha ma'lumotlar tozalanadi. Ishonchingiz komilmi?")) {
                location.reload();
            }
        }

        // Navigation
        function showScreen(screenId) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(screenId).classList.add('active');
        }

        function switchTab(screenId, btnElement) {
            showScreen(screenId);
            document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
            btnElement.classList.add('active');
        }

        // Modal logic
        function openNewChatModal() {
            document.getElementById('new-chat-modal').classList.add('active');
            document.getElementById('peer-id-input').value = '';
            document.getElementById('new-chat-error').style.display = 'none';
            setTimeout(() => document.getElementById('peer-id-input').focus(), 100);
        }

        function closeNewChatModal() {
            document.getElementById('new-chat-modal').classList.remove('active');
        }

        function formatIdInput(input) {
            let val = input.value.replace(/\D/g, '');
            if (val.length > 3) {
                val = val.substring(0, 3) + '-' + val.substring(3, 6);
            }
            input.value = val;
        }

        function startNewChat() {
            const peerId = document.getElementById('peer-id-input').value;
            const errorMsg = document.getElementById('new-chat-error');
            const confirmBtn = document.querySelector('.btn-confirm');
            errorMsg.style.display = 'none';

            if (peerId.length !== 7 || peerId === myId) {
                errorMsg.textContent = "To'g'ri ID kiriting!";
                errorMsg.style.display = 'block';
                return;
            }

            if (connections[peerId]) {
                closeNewChatModal();
                openChat(peerId);
                return;
            }

            // Dastlab LocalStorage tekshiramiz (eng tezkor va ishinchlisi xuddi shu kompyuterdagisiga)!
            const lastBeat = localStorage.getItem('webmessage_beat_' + peerId);
            if (lastBeat && (Date.now() - parseInt(lastBeat)) <= 5000) {
                // Mahalliy foydalanuvchi bor, darhol ochamiz!
                connections[peerId] = { isLocalOnly: true };
                if (!chats[peerId]) chats[peerId] = [];
                closeNewChatModal();
                openChat(peerId);
                renderChatList();
                
                // Va fonga WebRTC ga harakat qilib quyamiz ehtimoldan xoli qimasdan
                if (peer && !peer.disconnected && !peer.destroyed) {
                    peer.connect(peerId, { reliable: true });
                }
                return;
            }

            confirmBtn.disabled = true;
            confirmBtn.textContent = 'Qidirilmoqda...';
            errorMsg.style.display = 'none';

            // Agar qachondir tab ochiq qolib internet yoki server uzilgan bo'lsa darhol qayta ulaymiz
            if (peer && peer.disconnected && !peer.destroyed) {
                peer.reconnect();
                setTimeout(() => {
                    if (!peer.disconnected) {
                        attemptPeerConnect(peerId, confirmBtn, errorMsg);
                    } else {
                        errorMsg.textContent = "Tarmoq bilan aloqa yo'q. Internetni tekshiring!";
                        errorMsg.style.display = 'block';
                        confirmBtn.disabled = false;
                        confirmBtn.textContent = 'Suhbatlashish';
                    }
                }, 1500); // Kichik kutish
                return;
            }

            attemptPeerConnect(peerId, confirmBtn, errorMsg);
        }

        function attemptPeerConnect(peerId, confirmBtn, errorMsg) {
            const conn = peer.connect(peerId, { reliable: true });
            
            conn.on('open', () => {
                confirmBtn.disabled = false;
                confirmBtn.textContent = 'Suhbatlashish';
                setupConnection(conn);
                closeNewChatModal();
                openChat(peerId);
            });
            
            conn.on('error', (err) => {
                // error handler is tracked in outer peer.on('error')
            });
        }

        // Chat List Logic
        function renderChatList() {
            const chatListEl = document.getElementById('chat-list');
            const emptyStateEl = document.getElementById('empty-chat-state');

            chatListEl.innerHTML = '';
            const peerIds = Object.keys(chats);

            if (peerIds.length === 0) {
                emptyStateEl.style.display = 'flex';
            } else {
                emptyStateEl.style.display = 'none';
                peerIds.forEach(peerId => {
                    const messages = chats[peerId];
                    let lastMsg = 'Suhbat boshlandi...';
                    if (messages.length > 0) {
                        const lastObj = messages[messages.length - 1];
                        if (lastObj.type === 'text') lastMsg = lastObj.content;
                        else if (lastObj.type === 'image') lastMsg = '📷 Rasm';
                        else if (lastObj.type === 'audio') lastMsg = '🎤 Ovozli xabar';
                    }

                    const li = document.createElement('li');
                    li.className = 'chat-item';
                    li.onclick = () => openChat(peerId);

                    let badgeHtml = '';
                    if (unreadCounts[peerId]) {
                        badgeHtml = `<div class="unread-badge">${unreadCounts[peerId]}</div>`;
                    }

                    li.innerHTML = `
                        <div class="avatar"><i class="fa-solid fa-user"></i></div>
                        <div class="chat-info">
                            <div class="chat-name">${peerId}</div>
                            <div class="chat-preview">${lastMsg}</div>
                        </div>
                        ${badgeHtml}
                    `;
                    chatListEl.appendChild(li);
                });
            }
        }

        // Chat View Logic
        function openChat(peerId) {
            currentActiveChatId = peerId;
            unreadCounts[peerId] = 0;
            renderChatList();
            document.getElementById('current-chat-name').textContent = peerId;
            showScreen('chat-view-screen');
            renderMessages();
        }

        function closeChat() {
            currentActiveChatId = null;
            editingMessageId = null;
            document.getElementById('message-input').value = '';
            showScreen('chat-list-screen');
            renderChatList();
        }

        function formatTime(timestamp) {
            const d = new Date(timestamp);
            return d.getHours().toString().padStart(2, '0') + ':' + d.getMinutes().toString().padStart(2, '0');
        }

        function renderMessages() {
            if (!currentActiveChatId) return;

            const container = document.getElementById('messages-container');
            container.innerHTML = '';
            const messages = chats[currentActiveChatId] || [];

            messages.forEach(msg => {
                const div = document.createElement('div');
                div.className = `message ${msg.sender === 'me' ? 'sent' : 'received'}`;
                div.id = `msg-${msg.id}`;

                let actionsHtml = '';
                if (msg.sender === 'me') {
                    actionsHtml = `
                        <div class="msg-actions">
                            <button onclick="editMessage('${msg.id}')"><i class="fa-solid fa-pen"></i></button>
                            <button onclick="deleteMessage('${msg.id}')"><i class="fa-solid fa-trash"></i></button>
                        </div>
                    `;
                }

                let contentHtml = '';
                if (msg.type === 'text') {
                    contentHtml = `<div class="text">${msg.content}</div>`;
                } else if (msg.type === 'image') {
                    let imgs = Array.isArray(msg.content) ? msg.content : [msg.content];
                    if (imgs.length === 1) {
                        contentHtml = `<img src="${imgs[0]}" class="msg-image" alt="Rasm">`;
                    } else if (imgs.length > 1) {
                        contentHtml = `<div class="img-grid">`;
                        imgs.forEach(i => { contentHtml += `<img src="${i}" alt="Rasm">`; });
                        contentHtml += `</div>`;
                    }
                    if (msg.caption) {
                        contentHtml += `<div class="text" style="margin-top: 5px;">${msg.caption}</div>`;
                    }
                } else if (msg.type === 'audio') {
                    contentHtml = `<audio controls src="${msg.content}" class="msg-audio"></audio>`;
                    if (msg.caption) {
                        contentHtml += `<div class="text" style="margin-top: 5px;">${msg.caption}</div>`;
                    }
                }

                let editedTagHtml = msg.isEdited ? `<span class="edited-tag">tahrirlangan</span>` : '';

                div.innerHTML = `
                    ${contentHtml}
                    <div class="msg-time flex justify-center items-center" style="justify-content: flex-end;">${editedTagHtml}${formatTime(msg.timestamp)}</div>
                    ${actionsHtml}
                `;
                container.appendChild(div);
            });

            container.scrollTop = container.scrollHeight;
        }

        function addMessageToChat(type, content, caption = '') {
            if (!currentActiveChatId) return;

            let msgObj = null;

            if (editingMessageId) {
                const msg = chats[currentActiveChatId].find(m => m.id === editingMessageId);
                if (msg) {
                    let isChanged = false;
                    if (msg.type === 'text' && msg.content !== content) isChanged = true;
                    else if (msg.type !== 'text') {
                        if (msg.caption !== caption) isChanged = true;
                        if (JSON.stringify(msg.content) !== JSON.stringify(content)) isChanged = true;
                    }

                    if (isChanged) {
                        msg.content = content;
                        msg.caption = caption;
                        msg.isEdited = true;
                    }
                    msgObj = msg;
                }
                editingMessageId = null;
            } else {
                msgObj = {
                    id: Date.now().toString() + Math.random().toString(36).substr(2, 5),
                    type: type,
                    content: content,
                    caption: caption,
                    sender: 'me',
                    timestamp: Date.now(),
                    isEdited: false
                };
                chats[currentActiveChatId].push(msgObj);
            }

            if (msgObj) {
                const bMsg = {
                    id: msgObj.id,
                    type: msgObj.type,
                    content: msgObj.content,
                    caption: msgObj.caption,
                    sender: myId,
                    recipient: currentActiveChatId,
                    timestamp: msgObj.timestamp,
                    isEdited: msgObj.isEdited
                };

                // Har doim WebRTC orqali yuboramiz (agar to'liq ulangan bo'lsa isLocalOnly false)
                if (connections[currentActiveChatId] && !connections[currentActiveChatId].isLocalOnly) {
                    connections[currentActiveChatId].send(bMsg);
                }
                
                // Va har doim ikkilamchi kafolat uchun LocalStorage dan ham yuboramiz (huddi shu brauzerlar uchun)
                localStorage.setItem('webmessage_broadcast', JSON.stringify(bMsg));
            }

            renderMessages();
            renderChatList();
        }

        function sendMessage() {
            const input = document.getElementById('message-input');
            const text = input.value.trim();
            
            if (pendingMedia.type === 'image') {
                if (pendingMedia.images.length === 0) {
                    // if images were removed while editing, fallback to text if any
                    if (text) addMessageToChat('text', text);
                } else {
                    addMessageToChat('image', pendingMedia.images, text);
                }
                cancelMediaPreview();
                input.value = '';
                return;
            }

            if (pendingMedia.type === 'audio') {
                addMessageToChat('audio', pendingMedia.audio, text);
                cancelMediaPreview();
                input.value = '';
                return;
            }

            if (!text) return;

            addMessageToChat('text', text);
            input.value = '';
            cancelMediaPreview();
        }

        // Listen for Enter key
        document.getElementById('message-input').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });

        // Media Handling
        function triggerImageUpload() {
            document.getElementById('image-upload').click();
        }

        function renderMediaPreview() {
            const list = document.getElementById('preview-list');
            list.innerHTML = '';
            document.getElementById('add-more-img').classList.add('hidden');

            if (pendingMedia.type === 'image') {
                pendingMedia.images.forEach((imgSrc, idx) => {
                    const div = document.createElement('div');
                    div.className = 'preview-item';
                    div.innerHTML = `
                        <img src="${imgSrc}" class="image-preview-thumb">
                        <div class="remove-media-btn" onclick="removePendingImage(${idx})"><i class="fa-solid fa-xmark"></i></div>
                    `;
                    list.appendChild(div);
                });
                document.getElementById('add-more-img').classList.remove('hidden');
            } else if (pendingMedia.type === 'audio') {
                const div = document.createElement('div');
                div.className = 'preview-item';
                div.innerHTML = `<audio controls src="${pendingMedia.audio}" style="height: 40px; margin-top: 10px;"></audio>`;
                list.appendChild(div);
            }

            if (pendingMedia.type) {
                document.getElementById('image-preview-area').classList.add('active');
            } else {
                document.getElementById('image-preview-area').classList.remove('active');
            }
        }

        function sendImage(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    if (pendingMedia.type !== 'image') {
                        pendingMedia = { type: 'image', images: [], audio: null };
                    }
                    pendingMedia.images.push(e.target.result);
                    renderMediaPreview();
                    document.getElementById('message-input').focus();
                }
                reader.readAsDataURL(file);
                event.target.value = ''; 
            }
        }

        function removePendingImage(idx) {
            pendingMedia.images.splice(idx, 1);
            if (pendingMedia.images.length === 0) {
                cancelMediaPreview();
            } else {
                renderMediaPreview();
            }
        }

        function cancelMediaPreview() {
            pendingMedia = { type: null, images: [], audio: null };
            document.getElementById('image-preview-area').classList.remove('active');
            if (editingMessageId && pendingMedia.type !== null) {
                editingMessageId = null;
                document.getElementById('message-input').value = '';
            }
        }

        // Audio Recording Handling
        async function toggleRecording() {
            const micBtn = document.getElementById('mic-btn');
            const inputField = document.getElementById('message-input');

            if (!isRecording) {
                try {
                    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                    mediaRecorder = new MediaRecorder(stream);

                    mediaRecorder.ondataavailable = e => {
                        audioChunks.push(e.data);
                    };

                    mediaRecorder.onstop = () => {
                        const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                        // ObjectURL browserlar orasida ishlamaydi (Blob faqat local xotirada bo'ladi).
                        // Uni barcha joyda ishlashi uchun Base64 Data URL ga o'giramiz.
                        const reader = new FileReader();
                        reader.readAsDataURL(audioBlob);
                        reader.onloadend = () => {
                            const base64AudioUrl = reader.result;
                            pendingMedia = { type: 'audio', images: [], audio: base64AudioUrl };
                            renderMediaPreview();
                            document.getElementById('message-input').focus();
                            audioChunks = [];
                        };
                    };

                    audioChunks = [];
                    mediaRecorder.start();
                    isRecording = true;
                    micBtn.classList.add('recording');
                    inputField.placeholder = "Ovoz yozilmoqda...";
                    inputField.disabled = true;
                } catch (err) {
                    alert("Mikrofonga ruxsat berilmadi yoki mavjud emas!");
                }
            } else {
                mediaRecorder.stop();
                mediaRecorder.stream.getTracks().forEach(track => track.stop());
                isRecording = false;
                micBtn.classList.remove('recording');
                inputField.placeholder = "Xabar yozing...";
                inputField.disabled = false;
            }
        }

        function editMessage(msgId) {
            const msg = chats[currentActiveChatId].find(m => m.id === msgId);
            if (msg) {
                editingMessageId = msgId;
                document.getElementById('message-input').focus();

                if (msg.type === 'text') {
                    document.getElementById('message-input').value = msg.content;
                    cancelMediaPreview();
                    editingMessageId = msgId; // restore since cancel wipes it
                } else if (msg.type === 'image') {
                    document.getElementById('message-input').value = msg.caption || '';
                    pendingMedia = { type: 'image', images: Array.isArray(msg.content) ? [...msg.content] : [msg.content], audio: null };
                    renderMediaPreview();
                } else if (msg.type === 'audio') {
                    document.getElementById('message-input').value = msg.caption || '';
                    pendingMedia = { type: 'audio', images: [], audio: msg.content };
                    renderMediaPreview();
                }
            }
        }

        function deleteMessage(msgId) {
            if (confirm("Xabarni o'chirishni xohlaysizmi?")) {
                chats[currentActiveChatId] = chats[currentActiveChatId].filter(m => m.id !== msgId);
                renderMessages();
            }
        }

    </script>

